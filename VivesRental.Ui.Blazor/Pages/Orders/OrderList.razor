@page "/orders"
@inject VivesRental.Ui.Blazor.Sdk.OrderSdkService OrderService
@inject NavigationManager Navigation

<PageTitle>Orders</PageTitle>

<h3>Orders</h3>

<AuthorizeView Roles="Medewerker">
    <Authorized>
        <button class="btn btn-primary mb-3" @onclick="CreateNew" disabled="@isBusy">Create order</button>
    </Authorized>
</AuthorizeView>

@if (isBusy)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Customer</th>
                <th>Created</th>
                <th>Returned</th>
                <th>Lines</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in orders)
            {
                <tr>
                    <td>@($"{o.CustomerFirstName} {o.CustomerLastName}")</td>
                    <td>@o.CreatedAt.ToString("g")</td>
                    <td>@(o.ReturnedAt.HasValue ? o.ReturnedAt.Value.ToString("g") : "-")</td>
                    <td>@o.NumberOfOrderLines</td>
                    <td>
                        <a class="btn btn-sm btn-link" @onclick="() => ShowDetails(o.Id)">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<VivesRental.Services.Model.Results.OrderResult> orders = new();
    private bool isBusy = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        isBusy = true;
        error = null;
        try
        {
            orders = await OrderService.GetAll();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void CreateNew() => Navigation.NavigateTo("/orders/create");
    private void ShowDetails(Guid id) => Navigation.NavigateTo($"/orders/{id}");
}
