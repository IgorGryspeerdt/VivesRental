@page "/orders/create"
@inject VivesRental.Ui.Blazor.Sdk.OrderSdkService OrderService
@inject VivesRental.Ui.Blazor.Sdk.CustomerSdkService CustomerService
@inject NavigationManager Navigation
@using VivesRental.Services.Model.Results
@using System.ComponentModel.DataAnnotations

<PageTitle>Create order</PageTitle>

<h3>Create order</h3>

@if (isBusy)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <EditForm Model="model" OnValidSubmit="CreateOrder">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Customer</label>
            <InputSelect @bind-Value="model.CustomerId" class="form-select">
                <option value="">-- select customer --</option>
                @foreach (var c in customers)
                {
                    <option value="@c.Id">@($"{c.FirstName} {c.LastName} ({c.Email})")</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => model.CustomerId)" />
        </div>

        <button class="btn btn-primary" type="submit">Create</button>
        <button class="btn btn-secondary ms-2" type="button" @onclick="Cancel">Cancel</button>
    </EditForm>
}

@code {
    private List<CustomerResult> customers = new();
    private CreateOrderModel model = new();
    private bool isBusy = false;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        isBusy = true;
        try
        {
            customers = await CustomerService.GetAll();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task CreateOrder()
    {
        error = null;
        if (model.CustomerId == null || model.CustomerId == Guid.Empty)
        {
            error = "Select a customer.";
            return;
        }

        isBusy = true;
        try
        {
            var created = await OrderService.Create(model.CustomerId.Value);
            if (created == null)
            {
                error = "Could not create order.";
                return;
            }
            Navigation.NavigateTo($"/orders/{created.Id}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/orders");

    private class CreateOrderModel
    {
        [Required(ErrorMessage = "Customer is required")]
        public Guid? CustomerId { get; set; }
    }
}
