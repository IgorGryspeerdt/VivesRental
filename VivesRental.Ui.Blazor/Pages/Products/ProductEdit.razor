VivesRental.Ui.Blazor/Pages/Products/ProductEdit.razor
@page "/products/edit"
@page "/products/edit/{id:guid}"
@inject VivesRental.Ui.Blazor.Sdk.ProductSdkService ProductService
@inject NavigationManager Navigation
@using System.ComponentModel.DataAnnotations
@using VivesRental.Services.Model.Requests
@using VivesRental.Ui.Blazor.Sdk.Models

<PageTitle>Product edit</PageTitle>

<h3>@(isEdit ? "Edit product" : "Create product")</h3>

@if (isBusy)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <EditForm Model="model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText @bind-Value="model.Name" class="form-control" />
            <ValidationMessage For="@(() => model.Name)" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea @bind-Value="model.Description" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Manufacturer</label>
            <InputText @bind-Value="model.Manufacturer" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Publisher</label>
            <InputText @bind-Value="model.Publisher" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Rental expires after (days)</label>
            <InputNumber @bind-Value="model.RentalExpiresAfterDays" class="form-control" />
        </div>
        <button class="btn btn-primary" type="submit">Save</button>
        <button class="btn btn-secondary ms-2" type="button" @onclick="Cancel">Cancel</button>
    </EditForm>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private ProductRequest model = new();
    private bool isEdit => Id.HasValue;
    private bool isBusy = false;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        if (isEdit)
        {
            isBusy = true;
            try
            {
                var existing = await ProductService.Get(Id!.Value);
                if (existing == null)
                {
                    error = "Product not found.";
                    return;
                }
                model = new ProductRequest
                {
                    Name = existing.Name,
                    Description = existing.Description,
                    Manufacturer = existing.Manufacturer,
                    Publisher = existing.Publisher,
                    RentalExpiresAfterDays = existing.RentalExpiresAfterDays
                };
            }
            catch (Exception ex)
            {
                error = ex.Message;
            }
            finally
            {
                isBusy = false;
            }
        }
    }

    private async Task HandleSubmit()
    {
        error = null;
        isBusy = true;
        try
        {
            if (isEdit)
            {
                var updated = await ProductService.Update(Id!.Value, model);
                if (updated == null)
                {
                    error = "Update failed.";
                    return;
                }
                Navigation.NavigateTo($"/products/{updated.Id}");
            }
            else
            {
                var created = await ProductService.Create(model);
                if (created == null)
                {
                    error = "Create failed.";
                    return;
                }
                Navigation.NavigateTo($"/products/{created.Id}");
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/products");
}
