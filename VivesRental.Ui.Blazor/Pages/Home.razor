@page "/"

<PageTitle>Home</PageTitle>

<h1>Rental dashboard</h1>

<div class="row g-3">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Products</h5>
                <p class="card-text">Browse and manage product categories.</p>
                <a class="btn btn-primary" href="/products">Open</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Articles</h5>
                <p class="card-text">Manage physical stock items (status, details).</p>
                <a class="btn btn-primary" href="/articles">Open</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Customers</h5>
                <p class="card-text">Create and update customers. Link customers to orders.</p>
                <a class="btn btn-primary" href="/customers">Open</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Reservations</h5>
                <p class="card-text">Create and view article reservations.</p>
                <a class="btn btn-primary" href="/reservations">Open</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Orders</h5>
                <p class="card-text">View all orders and process returns.</p>
                <a class="btn btn-primary" href="/orders">Open</a>
            </div>
        </div>
    </div>
</div>
