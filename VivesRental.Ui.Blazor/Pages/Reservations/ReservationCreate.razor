@page "/reservations/create"
@inject ArticleReservationSdkService ReservationService
@inject ArticleSdkService ArticleService
@inject CustomerSdkService CustomerService
@inject ProductSdkService ProductSdk
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@using System.ComponentModel.DataAnnotations
@using VivesRental.Services.Model.Requests
@using VivesRental.Services.Model.Results

<PageTitle>Create reservation</PageTitle>

<h3>Create reservation</h3>

@if (isBusy)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    @if (isMedewerker)
    {
        <EditForm Model="model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Product</label>
                <InputSelect @bind-Value="selectedProductId" class="form-select" @onchange="LoadAvailableArticles">
                    <option value="">-- select product --</option>
                    @foreach (var p in products)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Article</label>
                <InputSelect @bind-Value="model.ArticleId" class="form-select">
                    <option value="">-- select article --</option>
                    @foreach (var a in availableArticles)
                    {
                        <option value="@a.Id">@($"{a.ProductName} - {a.Id}")</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => model.ArticleId)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Customer</label>
                <InputSelect @bind-Value="model.CustomerId" class="form-select">
                    <option value="">-- select customer --</option>
                    @foreach (var c in customers)
                    {
                        <option value="@c.Id">@($"{c.FirstName} {c.LastName} ({c.Email})")</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => model.CustomerId)" />
            </div>

            <div class="mb-3">
                <label class="form-label">From</label>
                <InputDate @bind-Value="model.FromDateTime" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Until</label>
                <InputDate @bind-Value="model.UntilDateTime" class="form-control" />
            </div>

            <button class="btn btn-primary" type="submit">Create</button>
            <button class="btn btn-secondary ms-2" type="button" @onclick="Cancel">Cancel</button>
        </EditForm>
    }
    else
    {
        <div class="alert alert-warning">Only users in role <strong>Medewerker</strong> can create reservations. Please sign in with an account with that role.</div>
    }
}

@code {
    private ArticleReservationRequest model = new()
    {
        FromDateTime = DateTime.Now,
        UntilDateTime = DateTime.Now.AddHours(1)
    };

    private List<VivesRental.Services.Model.Results.ProductResult> products = new();
    private List<VivesRental.Services.Model.Results.ArticleResult> availableArticles = new();
    private List<CustomerResult> customers = new();
    private Guid? selectedProductId;
    private bool isBusy = true;
    private string? error;
    private bool isMedewerker = false;

    protected override async Task OnInitializedAsync()
    {
        isBusy = true;
        error = null;
        try
        {
            products = await ProductSdk.GetAll();
            customers = await CustomerService.GetAll();

            // determine role membership without using AuthorizeView templates (avoids context collisions)
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            isMedewerker = user?.IsInRole("Medewerker") ?? false;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task LoadAvailableArticles(ChangeEventArgs? e = null)
    {
        if (!selectedProductId.HasValue || selectedProductId == Guid.Empty)
        {
            availableArticles = new();
            return;
        }

        isBusy = true;
        error = null;
        try
        {
            availableArticles = await ArticleService.GetAvailable(selectedProductId.Value, DateTime.Now);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandleSubmit()
    {
        error = null;
        isBusy = true;
        try
        {
            var created = await ReservationService.Create(model);
            if (created == null)
            {
                error = "Create failed.";
                return;
            }
            Navigation.NavigateTo($"/reservations/{created.Id}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/reservations");
}
